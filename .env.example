# Comma-separated absolute paths to directories containing media files
MEDIA_DIRS=/mnt/media/movies,/mnt/media/tv

# Base URL used to build stream/thumb URLs for Chromecast (must be reachable from the Chromecast)
BASE_URL=http://raspberrypi.local:8000

# Server bind address and port
HOST=0.0.0.0
PORT=8000

# Run a library scan automatically when the server starts
SCAN_ON_STARTUP=true
